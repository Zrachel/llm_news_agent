# Environment variables template
# Copy to .env and fill in your values

# ===========================================
# LLM Provider (choose one)
# ===========================================
# Options: "anthropic" (recommended) or "openai"
LLM_PROVIDER=anthropic

# Anthropic API (recommended - supports Claude Opus/Sonnet)
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# OR OpenAI API (alternative)
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_BASE_URL=https://api.openai.com/v1

# ===========================================
# Telegram (required)
# ===========================================
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=123456789

# ===========================================
# Optional: Xiaohongshu
# ===========================================
# Get this from browser DevTools after logging in
# XIAOHONGSHU_COOKIE=your-cookie-here
